{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "allowJs": false,
    "skipLibCheck": true
  },
  "include": [
    "src/core/**/*.ts",
    "src/core/**/*.tsx",
    "src/modules/**/*.ts",
    "src/modules/**/*.tsx",
    "src/custom/**/*.ts",
    "src/custom/**/*.tsx",
    "src/vite-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "@archive",
    "api",
    "supabase",
    "supabase_central",
    "scripts",
    "src/core/pages/api",
    "src/core/components/Layout_restored.tsx",
    "src/core/pages/admin/SetupWizard.tsx",
    "src/core/pages/admin/saas/SystemWebhooks.tsx",
    "src/core/pages/public/SystemDebug.tsx"
  ]
}
