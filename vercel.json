{
    "functions": {
        "api/admin.ts": {
            "includeFiles": "src/migrations/**"
        }
    },
    "rewrites": [
        { "source": "/api/check-status", "destination": "/api/system?action=check-status" },
        { "source": "/api/health", "destination": "/api/system?action=health" },
        { "source": "/api/pagbank-callback", "destination": "/api/system?action=pagbank-oauth-callback" },
        { "source": "/api/auth/login", "destination": "/api/auth?route=login" },
        { "source": "/api/auth/register", "destination": "/api/auth?route=register" },
        { "source": "/api/auth/2fa", "destination": "/api/auth?route=2fa" },
        { "source": "/api/auth/security-event", "destination": "/api/auth?route=security-event" },
        { "source": "/api/proxy", "destination": "/api/system?action=proxy" },
        { "source": "/api/send-email", "destination": "/api/system?action=send-email" },
        { "source": "/api/setup-admin", "destination": "/api/installer?action=setup-admin" },
        { "source": "/api/admin/:action", "destination": "/api/admin?action=:action" },
        { "source": "/api/domains/:action", "destination": "/api/domains?action=:action" },
        { "source": "/api/installer/:action", "destination": "/api/installer?action=:action" },
        { "source": "/api/licenses/validate", "destination": "/api/licenses?action=validate" },
        { "source": "/api/stripe/create-payment-intent", "destination": "/api/payments?action=create-payment-intent" },
        { "source": "/api/security/:action", "destination": "/api/security?action=:action" },
        { "source": "/api/central/:endpoint", "destination": "/api/central-proxy?endpoint=:endpoint" },
        { "source": "/api/webhooks/:action", "destination": "/api/stripe?action=:action" },
        {
            "source": "/mp-api/:path*",
            "destination": "https://api.mercadopago.com/:path*"
        },
        {
            "source": "/((?!api/|mp-api/|@vite/|@react-refresh|@id/|src/|node_modules/|.*\\.).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "Strict-Transport-Security",
                    "value": "max-age=31536000; includeSubDomains"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
                },
                {
                    "key": "X-DNS-Prefetch-Control",
                    "value": "on"
                },
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self'; script-src 'self' https://sdk.mercadopago.com https://js.stripe.com https://assets.pagseguro.com.br https://www.googletagmanager.com https://connect.facebook.net https://analytics.tiktok.com https://challenges.cloudflare.com; script-src-elem 'self' 'unsafe-inline' https://sdk.mercadopago.com https://js.stripe.com https://assets.pagseguro.com.br https://www.googletagmanager.com https://connect.facebook.net https://analytics.tiktok.com https://challenges.cloudflare.com; script-src-attr 'none'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.mercadopago.com https://api.stripe.com https://api.pagseguro.com https://sandbox.api.pagseguro.com https://api.resend.com https://api.vercel.com https://api.github.com https://www.google-analytics.com https://stats.g.doubleclick.net https://challenges.cloudflare.com; frame-src 'self' https://js.stripe.com https://hooks.stripe.com https://www.googletagmanager.com https://www.youtube.com https://www.youtube-nocookie.com https://challenges.cloudflare.com; media-src 'self' blob: data: https:; worker-src 'self' blob:; manifest-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests; report-uri /api/security/csp-report; report-to csp-endpoint"
                },
                {
                    "key": "Reporting-Endpoints",
                    "value": "csp-endpoint=\"/api/security/csp-report\""
                },
                {
                    "key": "Report-To",
                    "value": "{\"group\":\"csp-endpoint\",\"max_age\":10886400,\"endpoints\":[{\"url\":\"/api/security/csp-report\"}],\"include_subdomains\":true}"
                }
            ]
        }
    ],
    "crons": [
        {
            "path": "/api/health",
            "schedule": "0 6 * * *"
        }
    ]
}
